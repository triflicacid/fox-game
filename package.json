{
  "name": "fox-game",
  "version": "1.0.0",
  "description": "a small typescript fox game",
  "main": "dist/electron/main.js",
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "copy:static": "cp static dist/web -r -Force",
    "build:client": "tsc -p tsconfig.json && vite build && npm run copy:static",
    "electron": "tsc -p electron/tsconfig.json && electron dist/electron/main.js",
    "electron:rebuild": "electron-rebuild -f -w ."
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@types/node": "^26.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "private": true,
  "dependencies": {
    "electron": "^43.1.1"
  }
}
